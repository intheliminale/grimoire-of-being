<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>In The Liminale — Grimoire of Being</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    :root {
      --black:    #080706;
      --deep:     #110f0c;
      --bark:     #1e1a15;
      --gold:     #C2AF70;
      --gold-dim: #8a7a4a;
      --sage:     #6D785A;
      --sage-lt:  #9aab85;
      --tan:      #AA8B69;
      --dust:     #d4b896;
      --ash:      #6a6255;
      --mist:     #c8bfb0;
      --ivory:    #ede8df;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--black);
      color: var(--mist);
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 17px;
      line-height: 1.7;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── GRAIN OVERLAY ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 999;
      opacity: 0.035;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 200px;
    }

    /* ── HERO ── */
    .hero {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 4rem 2rem;
      position: relative;
      background:
        radial-gradient(ellipse 80% 60% at 50% 0%, #2a1f0e44 0%, transparent 70%),
        radial-gradient(ellipse 60% 40% at 20% 80%, #1a2a1544 0%, transparent 60%),
        radial-gradient(ellipse 50% 50% at 80% 90%, #1a150a33 0%, transparent 60%),
        var(--black);
    }

    .hero::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 120px;
      background: linear-gradient(to bottom, transparent, var(--black));
      pointer-events: none;
    }

    .sigil {
      font-size: 2.2rem;
      color: var(--gold-dim);
      letter-spacing: 0.5rem;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: fadeUp 1.2s ease forwards 0.2s;
    }

    .hero-name {
      font-family: 'Cinzel', serif;
      font-size: clamp(2.8rem, 8vw, 6rem);
      font-weight: 400;
      letter-spacing: 0.18em;
      color: var(--ivory);
      line-height: 1.1;
      opacity: 0;
      animation: fadeUp 1.2s ease forwards 0.5s;
    }

    .hero-name span {
      display: block;
      font-size: 0.38em;
      letter-spacing: 0.5em;
      color: var(--gold);
      font-weight: 400;
      margin-top: 0.8rem;
      text-transform: uppercase;
    }

    .hero-sub {
      font-family: 'IM Fell English', serif;
      font-style: italic;
      font-size: 1.1rem;
      color: var(--ash);
      margin-top: 2rem;
      letter-spacing: 0.05em;
      opacity: 0;
      animation: fadeUp 1.2s ease forwards 0.9s;
    }

    .hero-rule {
      width: 160px;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--gold-dim), transparent);
      margin: 2.5rem auto;
      opacity: 0;
      animation: fadeUp 1.2s ease forwards 1.1s;
    }

    .scroll-hint {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      font-size: 0.75rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--ash);
      opacity: 0;
      animation: fadeUp 1s ease forwards 2s, pulse 3s ease-in-out infinite 3s;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(8,7,6,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid #2a2318;
      padding: 0.9rem 2rem;
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      flex-wrap: wrap;
    }

    nav a {
      font-family: 'Cinzel', serif;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ash);
      text-decoration: none;
      transition: color 0.3s;
    }
    nav a:hover { color: var(--gold); }

    /* ── SECTIONS ── */
    section {
      max-width: 960px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .section-label {
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--gold-dim);
      margin-bottom: 0.8rem;
    }

    .section-title {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 400;
      color: var(--ivory);
      margin-bottom: 1.5rem;
      letter-spacing: 0.06em;
    }

    .divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(to right, transparent, #2e2820, transparent);
      margin: 1.5rem 0 2.5rem;
    }

    /* ── CORE PLACEMENTS GRID ── */
    .placements-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1px;
      background: #1a1610;
      border: 1px solid #1a1610;
    }

    .placement-card {
      background: var(--deep);
      padding: 1.4rem 1.2rem;
      transition: background 0.3s;
      position: relative;
      overflow: hidden;
    }

    .placement-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 2px;
      height: 0;
      background: var(--gold);
      transition: height 0.4s ease;
    }

    .placement-card:hover { background: #161210; }
    .placement-card:hover::before { height: 100%; }

    .placement-body { font-size: 0.8rem; letter-spacing: 0.06em; color: var(--ash); text-transform: uppercase; margin-bottom: 0.3rem; }
    .placement-sign { font-family: 'Cinzel', serif; font-size: 1.05rem; color: var(--ivory); margin-bottom: 0.15rem; }
    .placement-detail { font-size: 0.82rem; color: var(--gold-dim); font-style: italic; }

    /* ── STELLIUM BLOCK ── */
    .stellium {
      border: 1px solid #2a2318;
      padding: 2rem;
      margin: 2rem 0;
      position: relative;
      background: linear-gradient(135deg, #0e0b08, #110f0a);
    }

    .stellium::before {
      content: attr(data-label);
      position: absolute;
      top: -0.6rem;
      left: 1.5rem;
      font-family: 'Cinzel', serif;
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      background: var(--black);
      padding: 0 0.8rem;
    }

    .stellium p {
      font-style: italic;
      color: var(--mist);
      font-size: 0.95rem;
      line-height: 1.8;
    }

    .stellium-planets {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 1rem;
    }

    .planet-tag {
      font-family: 'Cinzel', serif;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      color: var(--gold-dim);
      border: 1px solid #2a2318;
      padding: 0.25rem 0.7rem;
    }

    /* ── ASTEROIDS ── */
    .asteroid-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.2rem;
    }

    .asteroid-card {
      border: 1px solid #1e1a14;
      padding: 1.2rem 1.4rem;
      background: var(--deep);
      transition: border-color 0.3s;
    }

    .asteroid-card:hover { border-color: var(--gold-dim); }

    .asteroid-name {
      font-family: 'Cinzel', serif;
      font-size: 0.85rem;
      color: var(--gold);
      letter-spacing: 0.1em;
      margin-bottom: 0.2rem;
    }

    .asteroid-pos {
      font-size: 0.78rem;
      color: var(--ash);
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .asteroid-meaning {
      font-style: italic;
      font-size: 0.88rem;
      color: var(--mist);
      line-height: 1.6;
    }

    /* ── TAROT ── */
    .tarot-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1px;
      background: #1a1610;
      border: 1px solid #1a1610;
    }

    .tarot-card {
      background: var(--deep);
      padding: 1.2rem;
      text-align: center;
      transition: background 0.3s;
    }
    .tarot-card:hover { background: #121009; }

    .tarot-planet {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ash);
      margin-bottom: 0.4rem;
    }

    .tarot-glyph {
      font-size: 1.8rem;
      margin-bottom: 0.4rem;
      line-height: 1;
    }

    .tarot-card-name {
      font-family: 'Cinzel', serif;
      font-size: 0.78rem;
      color: var(--gold);
      letter-spacing: 0.08em;
      line-height: 1.4;
    }

    /* ── NUMEROLOGY ── */
    .num-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1px;
      background: #1a1610;
      border: 1px solid #1a1610;
      margin-bottom: 2rem;
    }

    .num-cell {
      background: var(--deep);
      flex: 1;
      min-width: 140px;
      padding: 1.5rem 1rem;
      text-align: center;
    }

    .num-number {
      font-family: 'Cinzel', serif;
      font-size: 3rem;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 0.4rem;
    }

    .num-label {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ash);
      margin-bottom: 0.5rem;
    }

    .num-meaning {
      font-style: italic;
      font-size: 0.85rem;
      color: var(--mist);
    }

    /* ── RITUAL ANCHORS ── */
    .anchor-list {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }

    .anchor-list li {
      border-left: 2px solid var(--sage);
      padding: 0.8rem 1rem;
      background: var(--deep);
      font-size: 0.92rem;
      color: var(--mist);
    }

    .anchor-list li strong {
      display: block;
      font-family: 'Cinzel', serif;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--sage-lt);
      margin-bottom: 0.3rem;
    }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 3rem 2rem;
      border-top: 1px solid #1a1610;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ash);
    }

    footer .mark {
      font-family: 'Cinzel', serif;
      color: var(--gold-dim);
      display: block;
      font-size: 1rem;
      letter-spacing: 0.3em;
      margin-bottom: 0.6rem;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.4; }
      50%       { opacity: 0.8; }
    }

    /* ── MOBILE ── */
    @media (max-width: 600px) {
      nav { gap: 1.2rem; }
      .placements-grid { grid-template-columns: repeat(2, 1fr); }
      .tarot-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
<header class="hero">
  <div class="sigil">☽ ♄ ♏ ☿ ♅</div>
  <h1 class="hero-name">
    In The Liminale
    <span>Grimoire of Being</span>
