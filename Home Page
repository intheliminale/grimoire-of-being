<!-- ═══════════════════════════════ STELLIA ═══════════════════════════════ -->
<section id="stellia" style="background: linear-gradient(to bottom, var(--black), #0a0805, var(--black)); max-width:100%; padding: 5rem 2rem;">
  <div style="max-width:960px; margin:0 auto;">
    <p class="section-label">Concentrated Power</p>
